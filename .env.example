# ================================================
# NEXUSLIFE — Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# MongoDB Connection String
# Get free DB at: https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/nexuslife?retryWrites=true&w=majority

# Session Secret — any long random string
SESSION_SECRET=nexuslife_super_secret_change_this_in_production_2024

# Anthropic API Key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Port (Render/Railway sets this automatically)
PORT=3000

# App URL (for production)
APP_URL=https://your-app.onrender.com
